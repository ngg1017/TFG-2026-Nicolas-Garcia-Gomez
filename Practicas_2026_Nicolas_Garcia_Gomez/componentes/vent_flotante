#Para crear botones
def boton_subida(texto: str, nombres: list[str], datos: list[float]) -> rx.Component:
    datos_final = []
    for nombre, dato in zip(nombres, datos):
        diccionario = {"name": nombre.split(".")[0][len(nombre)-8:], "valor": dato}
        datos_final.append(diccionario)